{
  "name": "seamless",
  "version": "0.2.0",
  "description": "Seamless — a session-aware control room for the GitHub Copilot CLI. Discover, resume, and live-monitor sessions, plus Room CLI: PIN-gated browser rooms that run short, fully-context-aware Copilot turns per project with on-disk accumulating memory.",
  "main": "src/electron/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "server": "node src/server/server.js",
    "dev": "node src/server/server.js",
    "test": "node test/test-core.mjs",
    "test:room": "node test/test-roomcli.mjs"
  },
  "keywords": [
    "github-copilot",
    "copilot-cli",
    "context-window",
    "token-usage",
    "session-manager",
    "control-room",
    "room-cli",
    "dashboard",
    "electron",
    "developer-tools"
  ],
  "author": "Amit Pandey (@amitpandeytiktok)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amitpandeytiktok/seamless.git"
  },
  "bugs": {
    "url": "https://github.com/amitpandeytiktok/seamless/issues"
  },
  "homepage": "https://github.com/amitpandeytiktok/seamless#readme",
  "engines": {
    "node": ">=22"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "files": [
    "src",
    "assets",
    "scripts/gen-icon.mjs",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "electron": "^33.2.1"
  }
}
